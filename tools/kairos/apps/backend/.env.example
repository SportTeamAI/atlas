# ── App ───────────────────────────────────────────────────────────────────
APP_ENV=development            # development | staging | production
APP_LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
APP_TIMEZONE=America/Bogota
APP_DEBUG=true

# ── Base de datos (PostgreSQL) ─────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=jornada_test
DB_USER=jornada
DB_PASSWORD=                  # solo en .env local / secret manager, nunca en repo

# ── Auth (JWT local; luego migra a Firebase del hub) ───────────────────────
FIREBASE_PROJECT_ID=deportivasvirtualsoft
# OBLIGATORIO en producción (si no, la app se niega a arrancar). >=32 chars.
# Generar con: python -c "import secrets;print(secrets.token_urlsafe(64))"
JWT_SECRET=
JWT_EXPIRA_HORAS=12
# URL del frontend para armar los enlaces de onboarding (crear contraseña):
FRONTEND_BASE_URL=http://localhost:5180

# ── Integración Buk (HR) ───────────────────────────────────────────────────
# El TOKEN es un SECRETO: va SOLO aquí (o en el secret manager del server), nunca en el
# repo ni en la BD ni en el front. Se genera en Buk › Configuración › Accesos API (solo
# lectura sobre Colaboradores).
BUK_TENANT=                   # subdominio: si tu Buk es https://virtualsoft.buk.co → virtualsoft
BUK_TOKEN=                    # auth_token de Buk (solo lectura)
BUK_PAIS=colombia

# ── API ────────────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8020
API_CORS_ORIGINS=http://localhost:5173

# ── Festivos (Colombia) ────────────────────────────────────────────────────
FESTIVOS_API_URL=https://festivos.com.co/api

# Selector "ver como" sin contrasena (header X-Demo-User). Apagado por defecto.
# Enciendelo SOLO en local: en produccion la app se niega a arrancar con esto en 1.
APP_DEMO_LOGIN=0

# ─── Base de datos ────────────────────────────────────────────────────────────
# Vacio = SQLite local (apps/backend/data/jornada.db). Para PostgreSQL en el VPS:
# DATABASE_URL=postgresql+psycopg://kairos:LA_CLAVE@localhost:5432/atlas
# Este archivo (.env.example) es la PLANTILLA y SI va a git: nunca pongas claves aqui.
# Las claves reales van en .env, que git ignora (verificado con: git check-ignore .env).
DATABASE_URL=
